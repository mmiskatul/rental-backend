APP_NAME=Rental Sphere API
APP_ENV=development
FRONTEND_ORIGIN=http://localhost:3000

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=rental_sphere

JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
RESET_TOKEN_EXPIRE_MINUTES=30
VERIFICATION_CODE_EXPIRE_MINUTES=10

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@example.com
SMTP_FROM_NAME=Rental Sphere
SMTP_USE_TLS=true

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=rental-sphere/cars

SEED_ADMIN_EMAIL=admin@rentalsphere.local
SEED_ADMIN_PASSWORD=Admin12345
SEED_ADMIN_NAME=Rental Sphere Admin
SEED_CUSTOMER_EMAIL=customer@rentalsphere.local
SEED_CUSTOMER_PASSWORD=Customer12345
SEED_CUSTOMER_NAME=Rental Sphere Customer
